# Local credentials for the datatracker uploader.
# Copy this file to .env (which is gitignored) and fill it in. Preferred instead:
# store the credentials in your OS keychain with  make store-credentials
#
DATATRACKER_USER=you@example.com
DATATRACKER_PASSWORD=

# Optional overrides:
# DATATRACKER=https://datatracker.ietf.org
# GROUP=<acronym>
